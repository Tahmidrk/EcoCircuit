{
  "name": "ecocircuit-ewaste-platform",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "E-waste collection, tracking, analytics, and route optimization platform",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "nodemon server/index.js",
    "dev:client": "vite",
    "start": "node server/index.js",
    "build": "vite build",
    "preview": "vite preview",
    "test": "node --test server/tests/*.test.js"
  },
  "nodemonConfig": {
    "watch": ["server"],
    "ext": "js,mjs,cjs",
    "ignore": ["data/**", "dist/**"]
  },
  "dependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "bcryptjs": "^2.4.3",
    "concurrently": "^9.1.2",
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.2",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.468.0",
    "nodemon": "^3.1.9",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-leaflet": "^4.2.1",
    "react-router-dom": "^7.1.1",
    "recharts": "^2.15.0",
    "vite": "^6.0.5"
  },
  "devDependencies": {}
}
